{
  "name": "ags-mcq",
  "version": "0.4.0",
  "private": true,
  "description": "This package provides multiple-choice question (MCQ) functionalities as a Hugo module. It includes components for creating, displaying, and evaluating MCQs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agsayyed/ags-mcq.git"
  },
  "author": "Abdul Sayyed <s.ghafoor@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/agsayyed/ags-mcq/issues"
  },
  "scripts": {
    "build": "echo 'No build step required'",
    "clean": "echo 'No clean step required'",
    "lint": "pnpm run lint:js && pnpm run lint:scss && pnpm run lint:md",
    "lint:js": "eslint --ext .js,.ts,.jsx,.tsx . && echo '✅ ESLint completed successfully'",
    "lint:scss": "stylelint '**/*.{css,scss}' && echo '✅ Stylelint completed successfully'",
    "lint:md": "markdownlint-cli2 '**/*.md' && echo '✅ Markdownlint completed successfully'",
    "format": "prettier --write '**/*.{js,ts,json,md,yml,yaml}' --ignore-path .prettierignore",
    "format:md": "prettier --write '**/*.md' --ignore-path .prettierignore"
  },
  "keywords": ["hugo", "module", "mcq", "multiple-choice", "question", "quiz"],
  "homepage": ""
}
